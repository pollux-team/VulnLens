{
  "name": "vulnlens",
  "displayName": "VulnLens",
  "description": "Real-time dependency vulnerability scanning with CVSS scores and inline version picker",
  "version": "0.1.0",
  "publisher": "pollux-team",
  "type": "module",
  "main": "./dist/extension.cjs",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pollux-team/VulnLens"
  },
  "keywords": [
    "vulnerability",
    "security",
    "dependency",
    "scanner",
    "npm",
    "audit",
    "cve",
    "cvss"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node esbuild.mjs",
    "test": "vitest run",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@vulnlens/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vulnlens.scan",
        "title": "VulnLens: Scan Workspace"
      },
      {
        "command": "vulnlens.clearCache",
        "title": "VulnLens: Clear Cache"
      },
      {
        "command": "vulnlens.showFinding",
        "title": "VulnLens: Show Finding Details"
      },
      {
        "command": "vulnlens.showDeprecation",
        "title": "VulnLens: Show Deprecation Info"
      },
      {
        "command": "vulnlens.updateDependency",
        "title": "VulnLens: Update Dependency Version"
      },
      {
        "command": "vulnlens.showVersionHistory",
        "title": "VulnLens: Show Version History"
      }
    ],
    "configuration": {
      "title": "VulnLens",
      "properties": {
        "vulnlens.minSeverity": {
          "type": "string",
          "default": "moderate",
          "enum": [
            "low",
            "moderate",
            "high",
            "critical"
          ],
          "description": "Minimum severity level to display"
        },
        "vulnlens.autoScanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan when a package.json is opened"
        },
        "vulnlens.allowNetwork": {
          "type": "boolean",
          "default": true,
          "description": "Allow network requests to OSV API"
        }
      }
    }
  }
}
