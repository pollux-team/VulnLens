{
  "name": "@vulnlens/engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Host-agnostic dependency vulnerability scanner engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pollux-team/VulnLens",
    "directory": "packages/engine"
  },
  "keywords": [
    "vulnerability",
    "security",
    "dependency",
    "scanner",
    "npm",
    "osv",
    "cve",
    "cvss",
    "audit"
  ],
  "author": "Pollux Team",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "lru-cache": "^11.5.2",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
